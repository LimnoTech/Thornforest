# USGS Water Data API key (OPTIONAL) — raises API rate limits.
# Data access works without a key; add one only if you hit rate limits.
#
# 1. Get a free key:  https://api.waterdata.usgs.gov/signup/
# 2. Copy this file:  cp .env.example .env
# 3. Paste your key below in .env (NOT here).
#
# .env is git-ignored — never commit your real key. This template is safe to commit.
API_USGS_PAT=your_api_key_here
